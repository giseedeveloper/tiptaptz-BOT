# ──────────────────────────────────────────────────────────────
# Laravel backend (business logic API)
# ──────────────────────────────────────────────────────────────
API_BASE_URL=https://tiptapafrica.co.tz/public/api/bot
BOT_TOKEN=your-sanctum-bearer-token-from-admin-bots-page

# Set false to fall back to numbered text menus (Baileys-style).
USE_INTERACTIVE_MENU=true

# Menu PDF only (default). Set true to re-enable WhatsApp text/list ordering.
# BOT_ORDER_ENABLED=false

# Mobile-money payments (order bill + tips: phone → amount → USSD push → status poll).
# ON by default; set false to hide the payment flows.
# INTEGRATED_PAYMENTS_ENABLED=true

# ──────────────────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_GRAPH_VERSION=v20.0

# ──────────────────────────────────────────────────────────────
# HTTP server (single port serves both webhook + internal notify)
# ──────────────────────────────────────────────────────────────
PORT=3000

# Internal notify endpoint: shared secret with Laravel for bill image push
NOTIFY_SECRET=change-me-to-a-long-random-string
# Bind to 127.0.0.1 when behind nginx; 0.0.0.0 inside Docker.
BIND=127.0.0.1
